<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required to bind to FcitxRemoteService (protectionLevel="signature"):
         only works when both this plugin and fcitx5-android share the same signing cert,
         i.e. both are debug builds signed with the standard Android debug keystore. -->
    <uses-permission android:name="${fcitxAppId}.permission.IPC" />

    <application
        android:name="org.fcitx.fcitx5.android.plugin.clipboard.PluginApplication"
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault.Light"
        android:usesCleartextTraffic="true">

        <meta-data
            android:name="org.fcitx.fcitx5.android.plugin"
            android:resource="@xml/plugin" />

        <activity
            android:name="org.fcitx.fcitx5.android.plugin.clipboard.PluginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="${fcitxAppId}.plugin.MANIFEST" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <service
            android:name="org.fcitx.fcitx5.android.plugin.clipboard.MainService"
            android:exported="true"
            android:permission="${fcitxAppId}.permission.PLUGIN">
            <intent-filter>
                <action android:name="${fcitxAppId}.plugin.SERVICE" />
            </intent-filter>
        </service>

    </application>

</manifest>
