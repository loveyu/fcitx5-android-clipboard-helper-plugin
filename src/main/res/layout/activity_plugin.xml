<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 标题区 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_subtitle"
            android:textSize="13sp"
            android:textColor="#757575"
            android:paddingTop="4dp"
            android:paddingBottom="20dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="20dp" />

        <!-- 第一部分：POST 地址设置 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/current_url_label"
            android:textSize="12sp"
            android:textColor="#757575"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/current_url_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#1565C0"
            android:background="#E8F0FE"
            android:padding="10dp"
            android:layout_marginBottom="16dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:fontFamily="monospace" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/url_label"
            android:textSize="13sp"
            android:textColor="#616161"
            android:paddingBottom="4dp" />

        <EditText
            android:id="@+id/url_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/url_hint"
            android:inputType="textUri"
            android:maxLines="4"
            android:scrollHorizontally="false"
            android:paddingBottom="8dp" />

        <LinearLayout
            android:id="@+id/ignore_cert_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp"
            android:visibility="gone">

            <CheckBox
                android:id="@+id/ignore_cert_checkbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ignore_cert_label"
                android:textSize="14sp" />
        </LinearLayout>

        <Button
            android:id="@+id/save_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/save_settings" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="20dp" />

        <!-- 第二部分：上次读取的剪贴板内容 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/last_clipboard_title"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#424242"
            android:paddingBottom="12dp" />

        <TextView
            android:id="@+id/clipboard_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#424242"
            android:background="#F5F5F5"
            android:padding="12dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="28dp" />

        <!-- 底部文案 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/footer_text"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:gravity="center"
            android:paddingBottom="8dp" />

    </LinearLayout>
</ScrollView>

